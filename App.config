using System;
using System.Collections.Generic;
using System.IO;

namespace WxKeyExtractor
{
    internal static class WeChatDataLocator
    {
        internal static string FindFirstStorage()
        {
            return FindActiveStorage();
        }

        internal static string FindActiveStorage()
        {
            string documents = Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments);
            string[] roots =
            {
                Path.Combine(documents, "xwechat_files"),
                Path.Combine(documents, "WeChat Files")
            };
            string active = string.Empty;
            DateTime activeWrite = DateTime.MinValue;
            foreach (string root in roots)
            {
                foreach (string storage in FindAllUnderRoot(root))
                {
                    DateTime write = GetLatestDatabaseWrite(storage);
                    if (string.IsNullOrEmpty(active) || write > activeWrite)
                    {
                        active = storage;
                        activeWrite = write;
                    }
                }
            }
            return active;
        }

        internal static string NormalizeStorage(string selectedPath)
        {
            if (string.IsNullOrWhiteSpace(selectedPath)) return string.Empty;
            string path = Path.GetFullPath(selectedPath.Trim());
            if (IsStorage(path)) return path;
            string nested = Path.Combine(path, "db_storage");
            if (IsStorage(nested)) return nested;
            return FindUnderRoot(path);
        }

        private static string FindUnderRoot(string root)
        {
            foreach (string storage in FindAllUnderRoot(root)) return storage;
            return string.Empty;
        }

        private static IEnumerable<string> FindAllUnderRoot(string root)
        {
            if (!Directory.Exists(root)) yield break;
            if (IsStorage(root)) yield return root;
            string[] accounts;
            try
            {
                accounts = Directory.GetDirectories(root);
            }
            catch (UnauthorizedAccessException) { yield break; }
            catch (IOException) { yield break; }
            foreach (string account in accounts)
            {
                string storage = Path.Combine(account, "db_storage");
                if (IsStorage(storage)) yield return storage;
            }
        }

        private static DateTime GetLatestDatabaseWrite(string storage)
        {
            DateTime latest = Directory.GetLastWriteTimeUtc(storage);
            try
            {
                foreach (string file in Directory.EnumerateFiles(storage, "*.db*", SearchOption.AllDirectories))
                {
                    DateTime write = File.GetLastWriteTimeUtc(file);
                    if (write > latest) latest = write;
                }
            }
            catch (UnauthorizedAccessException) { }
            catch (IOException) { }
            return latest;
        }

        private static bool IsStorage(string path)
        {
            return Directory.Exists(path) && File.Exists(Path.Combine(path, "contact", "contact.db"));
        }
    }
}
